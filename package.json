  "license": "SEE LICENSE IN LICENSE",
  "homepage": "https://github.com/lexi2/speed-reader-widget#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lexi2/speed-reader-widget.git"
  },
  "bugs": {
    "url": "https://github.com/lexi2/speed-reader-widget/issues"
  },
  "keywords": [
    "rsvp",
    "speed-reading",
    "reading",
    "widget",
    "web-component",
    "shadow-dom",
    "ghost",
    "wordpress",
    "embed",
    "accessibility",
    "wcag",
    "a11y"
  ],
  "scripts": {
