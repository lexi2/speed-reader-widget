{
  "name": "speed-reader-widget",
  "version": "0.1.0",
  "description": "Embeddable RSVP (Rapid Serial Visual Presentation) reader widget. Single-script auto-install for Ghost, WordPress, and generic CMS sites.",
  "type": "module",
  "main": "dist/rsvp-reader.js",
  "files": [
    "dist",
    "LICENSE",
    "COMMERCIAL.md",
    "README.md"
  ],
