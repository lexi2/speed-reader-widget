{
  "name": "speed-reader-widget",
  "version": "0.3.0",
  "description": "Embeddable RSVP (Rapid Serial Visual Presentation) reader widget. Single-script auto-install for Ghost, WordPress, Substack, and any CMS. Includes timer, skip controls, theming, and accessible stage play UI.",
  "type": "module",
  "main": "dist/rsvp-reader.js",
  "module": "dist/rsvp-reader.js",
  "unpkg": "dist/rsvp-reader.iife.js",
  "jsdelivr": "dist/rsvp-reader.iife.js",
  "sideEffects": [
    "dist/rsvp-reader.iife.js",
    "src/index.ts"
  ],
  "files": [
    "dist",
    "LICENSE",
    "COMMERCIAL.md",
    "CHANGELOG.md",
    "README.md"
  ],
  "author": "Alex Rosewarne",
  "license": "SEE LICENSE IN LICENSE",
  "homepage": "https://demo.speedreaderwidget.xyz/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lexi2/speed-reader-widget.git"
  },
  "bugs": {
    "url": "https://github.com/lexi2/speed-reader-widget/issues"
  },
  "keywords": [
    "rsvp",
    "speed-reading",
    "reading",
    "widget",
    "web-component",
    "shadow-dom",
    "ghost",
    "wordpress",
    "substack",
    "embed",
    "accessibility",
    "wcag",
    "a11y"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "size": "gzip -c dist/rsvp-reader.iife.js | wc -c",
    "assemble:site": "npm run build && bash scripts/assemble-deploy-site.sh",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "prepublishOnly": "npm test && npm run build"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "terser": "^5.48.0",
    "typescript": "^5.4.0",
    "vite": "^6.4.3",
    "wrangler": "^4.100.0"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
